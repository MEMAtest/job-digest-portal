rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /interviews/{jobId}/{fileName} {
      allow read: if false;
      allow create: if request.resource.size < 209715200
                    && request.resource.contentType.matches('audio/.*|video/mp4|video/webm');
      allow update, delete: if false;
    }
  }
}
